{
  "name": "@alezhu/weex",
  "version": "1.0.6",
  "description": "npm package for getting week info",
  "main": "./dist/cjs/index.js",
  "types": "./dist/cjs/types/index.d.ts",
  "module": "./dist/esm/wrapper.mjs",
  "files": [
    "dist/**/*"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/esm/types/index.d.ts",
        "default": "./dist/esm/wrapper.mjs"
      },
      "require": {
        "types": "./dist/cjs/types/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "scripts": {
    "clean": "del-cli ./dist",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ci": "vitest --coverage",
    "build": "npm run clean && npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p ./tsconfig.esm.json && copyfiles --flat src/wrapper.mjs dist/esm && echo {\"type\": \"module\"} > dist/esm/package.json",
    "build:cjs": "tsc -p ./tsconfig.cjs.json && echo {\"type\": \"commonjs\"} > dist/cjs/package.json",
    "prepublishOnly": "npm run build",
    "npmjs:deploy": "npm config set //registry.npmjs.org/:_authToken=<token> && npm publish --access public",
    "version:patch": "npm version patch",
    "prepare": "husky || true",
    "commitmsg": "commitlint --edit"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alezhu/weex.git"
  },
  "keywords": [
    "week",
    "date",
    "calendar",
    "weeks"
  ],
  "author": "alezhu",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/alezhu/weex/issues"
  },
  "homepage": "https://github.com/alezhu/weex#readme",
  "devDependencies": {
    "@commitlint/cli": "^17.8.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@vitest/coverage-v8": "4.1.6",
    "@vitest/expect": "^4.1.6",
    "copyfiles": "^2.4.1",
    "del-cli": "^7.0.0",
    "husky": "^9.1.7",
    "move-file-cli": "^3.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}